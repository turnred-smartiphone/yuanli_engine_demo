page {
  --primary: #3B82F6;
  --primary-light: #EFF6FF;
  --success: #22C55E;
  --warning: #F59E0B;
  --danger: #EF4444;
  --text: #1F2937;
  --text-secondary: #6B7280;
  --text-light: #9CA3AF;
  --bg: #F3F4F6;
  --bg-white: #FFFFFF;
  --border: #E5E7EB;
  --radius: 12px;
  --shadow: 0 2px 12px rgba(0,0,0,0.06);

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.card {
  background: var(--bg-white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.card-value {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary);
}

.card-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

.grid-2 {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.grid-2 > .card {
  flex: 1;
  min-width: calc(50% - 10rpx);
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.mt-12 { margin-top: 12rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }

.text-center { text-align: center; }
.text-right { text-align: right; }
.text-secondary { color: var(--text-secondary); }
.text-primary { color: var(--primary); }
.text-danger { color: var(--danger); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary);
}

.tag-success {
  background: #ECFDF5;
  color: var(--success);
}

.tag-warning {
  background: #FFFBEB;
  color: var(--warning);
}

.tag-danger {
  background: #FEF2F2;
  color: var(--danger);
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
  margin-right: 8rpx;
}

.status-dot.pending { background: var(--warning); }
.status-dot.approved { background: var(--success); }
.status-dot.rejected { background: var(--danger); }

.van-toast {
  font-size: 28rpx;
}
