<view class="container">
  <view class="bind-header">
    <view class="step-title">欢迎使用源力引擎</view>
    <view class="step-desc">请填写以下信息完成绑定</view>
  </view>

  <view class="card">
    <van-cell-group inset>
      <van-field
        value="{{ form.studentId }}"
        label="学号/工号"
        placeholder="请输入学号或工号"
        required
        clearable
        bind:change="onStudentIdChange"
      />
      <van-field
        value="{{ form.name }}"
        label="姓名"
        placeholder="请输入真实姓名"
        required
        clearable
        bind:change="onNameChange"
      />
      <picker
        mode="selector"
        range="{{ roles }}"
        range-key="text"
        value="{{ roleIndex }}"
        bindchange="onRoleChange"
      >
        <van-cell
          title="角色"
          value="{{ roleName || '请选择角色' }}"
          is-link
          required
        />
      </picker>
      <picker
        mode="selector"
        range="{{ organizations }}"
        range-key="text"
        value="{{ orgIndex }}"
        bindchange="onOrgChange"
      >
        <van-cell
          title="所属组织"
          value="{{ orgName || '请选择组织' }}"
          is-link
          required
        />
      </picker>
    </van-cell-group>

    <view class="submit-area">
      <van-button
        type="primary"
        size="large"
        round
        block
        loading="{{submitting}}"
        bind:click="handleSubmit"
      >
        确认绑定
      </van-button>
    </view>
  </view>
</view>

<van-toast id="van-toast" />
