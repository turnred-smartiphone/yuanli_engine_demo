<view class="container">
  <view class="profile-card card">
    <view class="flex-row">
      <image class="avatar" src="{{ userInfo.avatar || '/images/default-avatar.jpg' }}" mode="aspectFill" />
      <view class="profile-info">
        <view class="profile-name">{{ userInfo.name || '未绑定' }}</view>
        <view class="profile-id">{{ userInfo.student_id || '' }}</view>
        <view class="profile-tags mt-12">
          <text class="tag tag-primary">{{ roleText }}</text>
          <text class="tag tag-success" wx:if="{{ orgText }}">{{ orgText }}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="menu-section card">
    <van-cell title="我的申请" icon="orders-o" is-link url="/pages/activity/my" wx:if="{{ isLogin }}" />
    <van-cell title="审批列表" icon="passed" is-link url="/pages/approval/list" wx:if="{{ isLogin && userInfo.role !== 'student' }}" />
    <van-cell title="发起通知" icon="chat-o" is-link url="/pages/notification/create" wx:if="{{ isLogin && userInfo.role !== 'student' }}" />
    <van-cell title="个人信息" icon="user-o" is-link wx:if="{{ isLogin }}" />
    <van-cell title="关于我们" icon="info-o" is-link />
  </view>

  <view class="logout-area" wx:if="{{ isLogin }}">
    <van-button type="default" size="large" round block bind:click="handleLogout">
      退出登录
    </van-button>
  </view>

  <view class="logout-area" wx:else>
    <van-button type="primary" size="large" round block bind:click="goLogin">
      登录 / 绑定账号
    </van-button>
  </view>
</view>
