.profile-card {
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #E5E7EB;
  flex-shrink: 0;
}

.profile-info {
  margin-left: 28rpx;
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
}

.profile-id {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 6rpx;
}

.profile-tags {
  display: flex;
  gap: 12rpx;
}

.menu-section {
  margin-bottom: 24rpx;
  padding: 0;
}

.logout-area {
  padding: 40rpx 0;
}
