.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  text-align: center;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1F2937;
}

.stat-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.progress-bar {
  width: 100%;
  height: 20rpx;
  background: #E5E7EB;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #22C55E, #4ADE80);
  border-radius: 10rpx;
}
