.dashboard-header {
  margin-bottom: 28rpx;
  padding-top: 8rpx;
}

.greeting {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1F2937;
}

.header-date {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}

.card-elevated {
  border-radius: 16rpx;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
  cursor: pointer;
}

.card-elevated:active {
  transform: scale(0.98);
}

.card-label {
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
}

.card-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.card-icon-warning { background: #FFFBEB; }
.card-icon-primary { background: #EFF6FF; }

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 24rpx;
}

.card-link {
  color: #3B82F6;
  font-size: 24rpx;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background: #E5E7EB;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B82F6, #60A5FA);
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.chart-container {
  padding-top: 20rpx;
  border-top: 1rpx solid #F3F4F6;
}

.chart-title {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 20rpx;
}

.mini-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 220rpx;
  padding: 0 8rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
}

.bar-fill {
  width: 40rpx;
  background: linear-gradient(0deg, #3B82F6, #93C5FD);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #6B7280;
  margin-top: 6rpx;
}

.bar-name {
  font-size: 18rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 80rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.rank-item:not(:last-child) {
  border-bottom: 1rpx solid #F3F4F6;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #6B7280;
  margin-right: 20rpx;
}

.rank-num.rank-top {
  background: #EFF6FF;
  color: #3B82F6;
}

.rank-name {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
}

.rank-count {
  font-size: 24rpx;
  color: #6B7280;
}

.empty-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
