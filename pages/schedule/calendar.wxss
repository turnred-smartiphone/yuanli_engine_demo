.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  position: relative;
}

.month-nav {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}

.today-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #3B82F6;
  background: #EFF6FF;
  border-radius: 20rpx;
}

.weekday-row {
  display: flex;
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
  padding: 12rpx 0;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx;
}

.day-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-num {
  font-size: 26rpx;
  color: #374151;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #3B82F6;
  margin-top: 4rpx;
}

.day-cell.other-month .day-num {
  color: #D1D5DB;
}

.day-cell.today {
  background: #EFF6FF;
  border-radius: 50%;
}

.day-cell.today .day-num {
  color: #3B82F6;
  font-weight: 700;
}

.day-cell.has-activity {
  font-weight: 500;
}

.card-count {
  font-size: 24rpx;
  color: #3B82F6;
}

.activity-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
  flex: 1;
}
